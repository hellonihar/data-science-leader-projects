DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_experiments
REDIS_URL=redis://localhost:6379/0
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173

# Groq API (LLM Provider)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_BASELINE=llama3-70b-8192
GROQ_MODEL_FINETUNED=llama3-70b-8192
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Hallucination Scorer
HALLUCINATION_ENTAILMENT_THRESHOLD=0.9
HALLUCINATION_CONTRADICTION_TOLERANCE=0.0
HALLUCINATION_MODEL=cross-encoder/nli-deberta-v3-base
HALLUCINATION_SCORE_ENABLED=true

# Statistical testing
STATS_CHISQ_ALPHA=0.05
STATS_TTEST_ALPHA=0.05
